{
  "name": "@probeo/anyserp",
  "version": "0.5.2",
  "description": "Unified SERP API router. 11 providers — Serper, SerpAPI, Google CSE, Bing, Brave, DataForSEO, SearchAPI, ValueSERP, ScrapingDog, Bright Data, SearchCans.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "serp",
    "search",
    "google",
    "bing",
    "brave",
    "serper",
    "serpapi",
    "dataforseo",
    "searchapi",
    "valueserp",
    "scrapingdog",
    "brightdata",
    "searchcans",
    "unified",
    "router"
  ],
  "author": "Probeo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/probeo-io/anyserp"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
